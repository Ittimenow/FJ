NODE_ENV=production

# Public Timeweb application URL. Replace with the technical domain first,
# then with your custom domain after it is attached.
APP_PUBLIC_URL=https://your-app.twc1.net
NEXTAUTH_URL=https://your-app.twc1.net
WEB_ORIGIN=https://your-app.twc1.net

# Generate real secrets before deployment:
# openssl rand -base64 32
AUTH_SECRET=replace-with-openssl-rand-base64-32
JWT_SECRET=replace-with-openssl-rand-base64-32
JWT_EXPIRES_IN=7d

# Use a persistent external PostgreSQL database, not a database inside
# the application container.
DATABASE_URL=postgresql://cashflow:strong-password@host:5432/cashflow?schema=public

# Optional. Uncomment only after creating Redis.
# REDIS_URL=redis://host:6379

# Internal container wiring. Usually do not change these for Timeweb Dockerfile deploy.
PORT=3000
API_HOST=127.0.0.1
API_PORT=4000
WEB_HOST=127.0.0.1
WEB_PORT=3001
API_URL=http://127.0.0.1:4000
API_PROXY_PATH=/backend
NEXT_PUBLIC_API_PROXY_PATH=/backend
NEXT_PUBLIC_SOCKET_PATH=/backend/socket.io

# The container runs prisma db push and seeds reference cards/professions only
# when they are empty. Set to false if you manage schema/data manually.
DATABASE_AUTO_SETUP=true
