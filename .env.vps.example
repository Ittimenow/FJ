# Use a domain when DNS is ready:
# APP_PUBLIC_HOST=fj.example.com
# APP_PUBLIC_URL=https://fj.example.com
#
# For a first HTTP-only test by server IP, use:
# APP_PUBLIC_HOST=:80
# APP_PUBLIC_URL=http://SERVER_IP
APP_PUBLIC_HOST=:80
APP_PUBLIC_URL=http://127.0.0.1
NEXTAUTH_URL=http://127.0.0.1
WEB_ORIGIN=http://127.0.0.1

NODE_ENV=production
AUTH_TRUST_HOST=true
AUTH_SECRET=replace-with-openssl-rand-base64-32
JWT_SECRET=replace-with-openssl-rand-base64-32
JWT_EXPIRES_IN=7d

POSTGRES_USER=cashflow
POSTGRES_PASSWORD=replace-with-openssl-rand-hex-24
POSTGRES_DB=cashflow

# Internal container wiring. Keep these values unless you change Dockerfile/startup ports.
PORT=3000
API_HOST=127.0.0.1
API_PORT=4000
WEB_HOST=127.0.0.1
WEB_PORT=3001
API_URL=http://127.0.0.1:4000
API_PROXY_PATH=/backend
NEXT_PUBLIC_API_PROXY_PATH=/backend
NEXT_PUBLIC_SOCKET_PATH=/backend/socket.io
DATABASE_AUTO_SETUP=true

# Optional for several app instances. For one VPS instance, leave it empty.
# To enable: set REDIS_URL=redis://redis:6379 and run compose with --profile redis.
REDIS_URL=
