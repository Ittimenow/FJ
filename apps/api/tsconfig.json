{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@cashflow/shared": ["../../packages/shared/dist/index.d.ts"],
      "@cashflow/shared/*": ["../../packages/shared/dist/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
